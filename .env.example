# =============================================================================
# AegisClaims AI Platform - Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aegisclaims

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# S3 Configuration (Document Storage)
S3_BUCKET_NAME=aegisclaims-documents

# AWS Bedrock (LLM for Coverage Reasoning)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# AWS SageMaker (Fraud Detection ML Model)
SAGEMAKER_ENDPOINT_NAME=aegisclaims-fraud-detection

# -----------------------------------------------------------------------------
# Authentication (AWS Cognito)
# -----------------------------------------------------------------------------
COGNITO_USER_POOL_ID=your_user_pool_id
COGNITO_CLIENT_ID=your_cognito_client_id

# -----------------------------------------------------------------------------
# OpenSearch (RAG Policy Retrieval)
# -----------------------------------------------------------------------------
OPENSEARCH_ENDPOINT=https://your-opensearch-domain.region.es.amazonaws.com
OPENSEARCH_INDEX=policies

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Backend server configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend API URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (set to false in production)
DEBUG=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT Secret for token signing (generate a strong random string)
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production

# API Keys (if needed for external integrations)
# API_KEY=your_api_key
